<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
	<Properties>
		<Property name="resolvedActiveProfile">${sys:testActiveProfile:-stdout}</Property>
		<Property name="activeLevel">TRACE</Property>
		<Property name="resolvedTestLogDir">${sys:testLogDir:-target/test-logs}</Property>
		<Property name="resolvedRollingFilename">${sys:testRollingFilename:-Log4j-test}</Property>
	</Properties>
	<Appenders>
		<Console name="stdout" target="SYSTEM_OUT" follow="true">
			<PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss,SSS} %t %-5p [%c{1}::%M %L]  %m%n" />
		</Console>
		<RollingFile append="false" name="rollingFile"
			fileName="${resolvedTestLogDir}/${resolvedRollingFilename}.log"
			filePattern="${resolvedTestLogDir}/archive/${resolvedRollingFilename}-%d{MM-dd-yyyy}-%i.log"
			immediateFlush="true">
			<PatternLayout>
				<Pattern>%d{yyyy-MM-dd HH:mm:ss,SSS} %t %-5p [%c{1}::%M %L] %m%n</Pattern>
			</PatternLayout>
			<Policies>
				<TimeBasedTriggeringPolicy />
				<SizeBasedTriggeringPolicy size="10 MB" />
			</Policies>
		</RollingFile>
	</Appenders>
	<Loggers>
		<Logger name="com.hoffnungland" level="${activeLevel}" additivity="false">
			<AppenderRef ref="${resolvedActiveProfile}" />
		</Logger>
		<Root level="error">
			<AppenderRef ref="${resolvedActiveProfile}" />
			<AppenderRef ref="rollingFile" />
		</Root>
	</Loggers>
</Configuration>
